---
import '../styles/global.css';
import { SITE_MAPS_URL, SITE_STREET } from '../data/site';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const siteOrigin = import.meta.env.SITE ?? 'https://serralheriaembotucatu.com.br';

const {
  title = 'Serralheria em Botucatu | Portões, Grades e Estruturas Metálicas',
  description =
    'Em Botucatu SP: portões, grades, coberturas e estruturas metálicas. Fabricação e instalação. Orçamento grátis.',
  canonical = 'https://serralheriaembotucatu.com.br',
  ogImage = '/og-image.png',
} = Astro.props;

const absoluteOgImage = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage.replace(/^\//, ''), `${siteOrigin}/`).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Serralheria Botucatu',
  description:
    'Serralheria em Botucatu SP - Fabricação e instalação de portões, grades, coberturas metálicas, pergolados e estruturas metálicas.',
  url: 'https://serralheriaembotucatu.com.br',
  telephone: '+55-14-98165-1674',
  email: 'contato@serralheriaembotucatu.com.br',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE_STREET,
    addressLocality: 'Botucatu',
    addressRegion: 'SP',
    addressCountry: 'BR',
  },
  hasMap: SITE_MAPS_URL,
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '18:00',
  },
  priceRange: '$$',
  image: absoluteOgImage,
  sameAs: ['https://www.instagram.com/serralheriaembotucatu/'],
  areaServed: {
    '@type': 'City',
    name: 'Botucatu',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Serviços de Serralheria',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Portões de Ferro' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Cobertura Metálica' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Grades e Cercas' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Manutenção de Serralheria' } },
    ],
  },
};
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth selection:bg-spark-500/30 selection:text-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fallback inline: garante cores visíveis mesmo sem CSS externo (Googlebot) -->
    <style is:inline>
      body { background-color: #18181b !important; color: #ffffff !important; }
      header { background-color: #18181b !important; }
      #hero { background-color: #3f3f46 !important; }
      #servicos { background-color: #18181b !important; }
      #sobre { background-color: #18181b !important; }
      #contato { background-color: #111111 !important; }
      footer, #localizacao { background-color: #111111 !important; }
      h1, h2, h3, p, li, a, span { color: #ffffff !important; }
    </style>

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Serralheria Botucatu" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Serralheria Botucatu" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />

    <!-- Fonts (link direto — evita @import bloquear renderização para crawlers) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Theme Color -->
    <meta name="theme-color" content="#b45309" />
  </head>
  <body class="min-h-screen flex flex-col font-sans text-base">
    <a href="#main-content" class="skip-link">Pular para o conteúdo principal</a>
    <slot />
  </body>
</html>
