---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ContactForm from '../components/ContactForm.astro';
import { Image } from 'astro:assets';
import aboutImg from '../assets/images/severino-oficina-3.png';
import '../styles/global.css';
---

<Layout
  title="Contato - Serralheria em Botucatu e Região - Serviço de Serralheiro"
  description="Nós adoraríamos ouvir de você. Entre em contato com a Serralheria em Botucatu para solicitar seu orçamento de portões, grades e estruturas metálicas."
  canonical="https://serralheriaembotucatu.com.br/contato/"
>
  <Header />

  <main id="main-content" class="pt-20">
    <!-- Hero Banner -->
    <section class="relative py-20 lg:py-28 bg-gray-900 overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        <Image
          src={aboutImg}
          alt="Equipe de serralheria trabalhando"
          class="w-full h-full object-cover"
          widths={[640, 960, 1280]}
          sizes="100vw"
          loading="eager"
          format="webp"
          quality={60}
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900 via-gray-900/95 to-gray-900/80"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <!-- Breadcrumb -->
        <nav class="flex justify-center mb-8" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-sm text-gray-400">
            <li><a href="/" class="hover:text-brand-400 transition-colors">Home</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-brand-400 font-medium">Contato</li>
          </ol>
        </nav>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white mb-6 animate-fade-in-up">
          CONTATO
        </h1>
        <p class="text-xl text-brand-300 font-medium mb-2 animate-fade-in-up" style="animation-delay: 0.1s">
          Nós adoraríamos ouvir de você
        </p>
      </div>
    </section>

    <!-- Contact Form Section -->
    <ContactForm />

  </main>

  <Footer />
  <WhatsAppButton />
</Layout>
