---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { Image } from 'astro:assets';
import { services } from '../data/services';
import '../styles/global.css';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

// Import all images dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.png', { eager: true });
const imagePath = `../assets/images/${service.image}.png`;
const imageModule = images[imagePath];
const serviceImage = imageModule ? imageModule.default : null;

// Get other services for "Outros Serviços" section
const otherServices = services.filter((s) => s.id !== service.id).slice(0, 6);
---

<Layout
  title={`${service.pageTitle} - Serralheria em Bauru e Região`}
  description={service.metaDescription}
  canonical={`https://serralheriaembauru.com.br/${service.slug}/`}
>
  <Header />

  <main id="main-content" class="pt-20">
    <!-- Hero Banner -->
    <section class="relative py-20 lg:py-28 bg-gray-900 overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        {serviceImage && (
          <Image
            src={serviceImage}
            alt={service.alt}
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="100vw"
            loading="eager"
            format="webp"
            quality={60}
          />
        )}
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900 via-gray-900/95 to-gray-900/80"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <!-- Breadcrumb -->
        <nav class="flex justify-center mb-8" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-sm text-gray-400">
            <li><a href="/" class="hover:text-brand-400 transition-colors">Home</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/#servicos" class="hover:text-brand-400 transition-colors">Serviços</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-brand-400 font-medium">{service.title}</li>
          </ol>
        </nav>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white mb-6 animate-fade-in-up">
          {service.title.toUpperCase()}
        </h1>
        <p class="text-xl text-brand-300 font-medium mb-2 animate-fade-in-up" style="animation-delay: 0.1s">
          Em Bauru
        </p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
          <!-- Main Content -->
          <div class="lg:col-span-3">
            <!-- Intro -->
            <p class="text-lg text-gray-600 leading-relaxed mb-10">
              {service.intro}
            </p>

            <!-- Sections -->
            {service.sections.map((section) => (
              <div class="mb-10">
                <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
                  <div class="w-1.5 h-8 bg-brand-600 rounded-full"></div>
                  {section.title}
                </h2>
                {section.items ? (
                  <ul class="space-y-4">
                    {section.items.map((item) => {
                      const [bold, ...rest] = item.split(':');
                      return rest.length > 0 ? (
                        <li class="flex items-start gap-3 text-gray-600">
                          <div class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center mt-0.5">
                            <svg class="w-3.5 h-3.5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                            </svg>
                          </div>
                          <span><strong class="text-gray-800">{bold}:</strong>{rest.join(':')}</span>
                        </li>
                      ) : (
                        <li class="flex items-start gap-3 text-gray-600">
                          <div class="flex-shrink-0 w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center mt-0.5">
                            <svg class="w-3.5 h-3.5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                            </svg>
                          </div>
                          <span>{item}</span>
                        </li>
                      );
                    })}
                  </ul>
                ) : section.text ? (
                  <p class="text-gray-600 leading-relaxed">{section.text}</p>
                ) : null}
              </div>
            ))}

            <!-- CTA -->
            <div class="mt-12 p-8 bg-gradient-to-r from-brand-600 to-brand-700 rounded-2xl text-center">
              <h3 class="text-2xl font-bold text-white mb-3">Solicite seu Orçamento Gratuito</h3>
              <p class="text-brand-100 mb-6">
                Entre em contato e receba uma proposta personalizada, sem custo adicional.
              </p>
              <a
                href="https://wa.me/5514996804609?text=Olá! Encontrei o contato de vocês através do site serralheriaembauru.com.br e gostaria de solicitar um orçamento"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 px-8 py-4 bg-white text-brand-700 font-bold rounded-xl hover:bg-brand-50 transition-all duration-300 hover:shadow-xl text-lg"
                aria-label={`Solicitar orçamento de ${service.title} pelo WhatsApp`}
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                ORÇAMENTO PELO WHATSAPP
              </a>
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="lg:col-span-2">
            <!-- Service Image -->
            {serviceImage && (
              <div class="rounded-2xl overflow-hidden shadow-xl mb-8">
                <Image
                  src={serviceImage}
                  alt={service.alt}
                  class="w-full h-auto object-cover"
                  widths={[400, 600]}
                  sizes="(max-width: 1024px) 100vw, 40vw"
                  loading="lazy"
                  format="webp"
                  quality={80}
                />
              </div>
            )}

            <!-- Contact Box -->
            <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Fale Conosco</h3>
              
              <div class="space-y-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500">Telefone</p>
                    <a href="tel:+5514996804609" class="font-semibold text-gray-800 hover:text-brand-600 transition-colors">(14) 99680-4609</a>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500">Horário</p>
                    <p class="font-semibold text-gray-800">Seg - Sex: 07:00 - 19:00</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500">Localização</p>
                    <p class="font-semibold text-gray-800">Bauru - SP</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Other Services -->
            <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Outros Serviços</h3>
              <ul class="space-y-2">
                {otherServices.map((s) => (
                  <li>
                    <a
                      href={`/${s.slug}/`}
                      class="flex items-center gap-2 py-2 px-3 text-sm text-gray-600 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-all duration-200"
                    >
                      <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                      {s.title}
                    </a>
                  </li>
                ))}
                <li>
                  <a
                    href="/#servicos"
                    class="flex items-center gap-2 py-2 px-3 text-sm font-semibold text-brand-600 hover:bg-brand-50 rounded-lg transition-all duration-200"
                  >
                    Ver todos os serviços →
                  </a>
                </li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</Layout>
