---
import Logo from './Logo.astro';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Serviços', href: '/#servicos' },
  { label: 'Sobre Nós', href: '/sobre-nos/' },
  { label: 'Contato', href: '/contato/' },
];

const waUrl =
  'https://wa.me/5514981651674?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembotucatu.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento';
---

<header
  id="header"
  class="fixed left-0 right-0 top-0 z-50 border-b border-white/[0.06] bg-steel-925/92 backdrop-blur-md transition-shadow duration-300"
>
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" aria-label="Navegação principal">
    <div class="flex h-16 items-center justify-between lg:h-[4.5rem]">
      <a href="/" class="group" aria-label="Serralheria Botucatu - Página Inicial">
        <Logo variant="header" class="group-hover:opacity-90 transition-opacity" />
      </a>

      <div class="hidden items-center gap-1 lg:flex">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-display rounded-sm px-4 py-2 text-sm uppercase tracking-[0.14em] text-zinc-400 transition-colors hover:bg-white/[0.05] hover:text-white"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden items-center gap-2 border border-zinc-500/40 bg-zinc-100/10 px-4 py-2.5 font-display text-sm uppercase tracking-[0.12em] text-zinc-100 transition-all hover:border-spark-500/50 hover:bg-spark-500/10 hover:text-spark-200 sm:inline-flex"
          aria-label="Solicitar orçamento gratuito de serralheria em Botucatu"
        >
          Orçamento
        </a>

        <button
          id="mobile-menu-toggle"
          class="rounded-sm p-2 text-zinc-400 transition-colors hover:bg-white/10 hover:text-white lg:hidden"
          aria-label="Abrir menu de navegação"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden border-t border-white/[0.06] pb-4 lg:hidden" role="navigation" aria-label="Menu mobile">
      <div class="flex flex-col gap-1 pt-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link rounded-sm px-4 py-3 font-display text-sm uppercase tracking-wide text-zinc-400 transition-colors hover:bg-white/[0.05] hover:text-white"
          >
            {link.label}
          </a>
        ))}
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-nav-link btn-whatsapp mx-4 mt-2 justify-center"
          aria-label="Solicitar orçamento gratuito"
        >
          Solicitar Orçamento
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    toggle.setAttribute('aria-label', isOpen ? 'Fechar menu de navegação' : 'Abrir menu de navegação');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header?.classList.add('shadow-lg', 'shadow-black/30');
    } else {
      header?.classList.remove('shadow-lg', 'shadow-black/30');
    }
  });
</script>
