---
import Logo from './Logo.astro';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Serviços', href: '/#servicos' },
  { label: 'Sobre Nós', href: '/sobre-nos/' },
  { label: 'Contato', href: '/contato/' },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 bg-steel-925/90 backdrop-blur-lg border-b border-white/[0.06] transition-all duration-300 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.04)]"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Navegação principal">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="group" aria-label="Serralheria Botucatu - Página Inicial">
        <Logo variant="header" class="group-hover:opacity-95 transition-opacity" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-display px-4 py-2 text-[13px] font-semibold uppercase tracking-wider text-zinc-400 hover:text-white hover:bg-white/[0.07] rounded-md transition-all duration-200"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA + Mobile Menu -->
      <div class="flex items-center gap-3">
        <a
          href="https://wa.me/5514981651674?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembotucatu.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-brand-600 to-brand-700 text-white text-xs font-display font-semibold uppercase tracking-wider rounded-md hover:from-brand-500 hover:to-brand-600 focus:outline-none focus:ring-4 focus:ring-brand-400/35 transition-all duration-300 shadow-industrial-sm hover:shadow-spark hover:-translate-y-0.5"
          aria-label="Solicitar orçamento gratuito de serralheria em Botucatu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Solicitar Orçamento
        </a>

        <!-- Mobile Toggle -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden p-2 text-gray-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors"
          aria-label="Abrir menu de navegação"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div
      id="mobile-menu"
      class="lg:hidden hidden pb-4 border-t border-gray-800 mt-2"
      role="navigation"
      aria-label="Menu mobile"
    >
      <div class="flex flex-col gap-1 pt-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link px-4 py-3 font-display text-sm font-semibold uppercase tracking-wide text-zinc-400 hover:text-white hover:bg-white/[0.07] rounded-md transition-all duration-200"
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://wa.me/5514981651674?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembotucatu.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento"
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-nav-link mt-2 mx-4 px-5 py-3.5 bg-gradient-to-r from-brand-600 to-brand-700 text-white text-center font-display font-semibold uppercase tracking-wider text-sm rounded-md hover:from-brand-500 hover:to-brand-600 transition-all duration-300 shadow-industrial-sm"
          aria-label="Solicitar orçamento gratuito"
        >
          Solicitar Orçamento
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    toggle.setAttribute('aria-label', isOpen ? 'Fechar menu de navegação' : 'Abrir menu de navegação');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Header scroll effect
  let lastScroll = 0;
  const header = document.getElementById('header');
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 100) {
      header?.classList.add('shadow-xl', 'shadow-black/10');
    } else {
      header?.classList.remove('shadow-xl', 'shadow-black/10');
    }
    lastScroll = currentScroll;
  });
</script>
