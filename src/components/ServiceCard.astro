---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  slug: string;
  imageSrc: ImageMetadata;
  alt: string;
  index?: number;
}

const { title, slug, imageSrc, alt, index = 0 } = Astro.props;
---

<article
  class="group plate-border bg-white rounded-lg overflow-hidden shadow-industrial-sm card-hover border border-zinc-200/90 ring-1 ring-black/[0.04]"
  style={`animation-delay: ${index * 0.08}s`}
>
  <!-- Image -->
  <div class="relative overflow-hidden aspect-[4/3]">
    <div
      class="absolute inset-0 z-[1] opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-t from-brand-900/50 via-transparent to-spark-500/10 pointer-events-none"
      aria-hidden="true"
    ></div>
    <Image
      src={imageSrc}
      alt={alt}
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
      widths={[320, 480, 640]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
      loading="lazy"
      format="webp"
      quality={75}
    />
    <div
      class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-zinc-900/70 via-zinc-900/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Content -->
  <div class="p-5 pt-6 border-t border-zinc-100 bg-gradient-to-b from-white to-zinc-50/50">
    <h2
      class="font-display text-lg font-bold text-zinc-900 mb-4 tracking-tight group-hover:text-brand-700 transition-colors duration-300 uppercase"
    >
      {title}
    </h2>
    <a
      href={`/${slug}/`}
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-brand-600 to-brand-700 text-white text-xs font-display font-semibold uppercase tracking-wider rounded-md hover:from-brand-500 hover:to-brand-600 focus:outline-none focus:ring-4 focus:ring-brand-300/50 transition-all duration-300 group-hover:shadow-spark group-hover:-translate-y-0.5"
      aria-label={`Saiba mais sobre ${title} em Botucatu`}
    >
      Saiba mais
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
