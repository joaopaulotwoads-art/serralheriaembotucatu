---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  slug: string;
  imageSrc: ImageMetadata;
  alt: string;
  categoryLabel: string;
  categoryFilter: string;
  intro: string;
  featured?: boolean;
  gridClass?: string;
  index?: number;
}

const { title, slug, imageSrc, alt, categoryLabel, categoryFilter, featured = false, gridClass = '', index = 0 } = Astro.props;
---

<a
  href={`/${slug}/`}
  class:list={[
    'service-card group flex flex-col bg-white',
    gridClass,
  ]}
  data-category={categoryFilter}
  data-service-card
  aria-label={`${title} — ${categoryLabel}`}
  style={`animation-delay: ${index * 0.06}s`}
>
  <!-- Imagem no topo -->
  <div class="relative overflow-hidden flex-shrink-0">
    <Image
      src={imageSrc}
      alt={alt}
      class:list={[
        'w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105',
        featured ? 'aspect-[16/9] lg:aspect-[4/3]' : 'aspect-[4/3]',
      ]}
      widths={featured ? [480, 640, 800, 960] : [320, 480, 640]}
      sizes={featured ? '(max-width: 1024px) 100vw, 50vw' : '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw'}
      loading="lazy"
      format="webp"
      quality={75}
    />
  </div>

  <!-- Título e categoria ABAIXO da imagem -->
  <div class="p-4 sm:p-5">
    <span class="font-display mb-2 block text-xs uppercase tracking-[0.16em] text-spark-600">
      {categoryLabel}
    </span>
    <h2
      class:list={[
        'font-display uppercase leading-[0.95] tracking-wide text-[#1a1a1a] transition-colors group-hover:text-spark-600',
        featured ? 'text-2xl sm:text-3xl' : 'text-xl sm:text-2xl',
      ]}
    >
      {title}
    </h2>
    <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-spark-600">
      Ver serviço
      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
