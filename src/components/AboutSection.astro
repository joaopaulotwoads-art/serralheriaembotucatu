---
import { Image } from 'astro:assets';
import aboutImg from '../assets/images/severino-oficina-1.png';
---

<section id="sobre" class="relative py-20 lg:py-28 bg-white overflow-hidden">
  <div class="absolute top-0 right-0 w-[min(100vw,520px)] h-[min(100vw,520px)] bg-mesh-light opacity-90 pointer-events-none rounded-full blur-3xl translate-x-1/3 -translate-y-1/4" aria-hidden="true"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text Content -->
      <div class="order-2 lg:order-1">
        <span class="eyebrow inline-block px-4 py-2 bg-spark-500/15 text-spark-800 rounded-sm mb-5 ring-1 ring-spark-500/25">
          Quem somos
        </span>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-zinc-900 mb-6 leading-[1.1] tracking-display-tight uppercase">
          Sobre <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-brand-800">Serralheria Botucatu</span>
        </h2>

        <div class="space-y-4 text-gray-600 leading-relaxed text-lg">
          <p>
            Com mais de 15 anos de experiência no mercado, nossa serralheria em Botucatu possui todo o conhecimento
            e mão de obra qualificada que sua obra necessita.
          </p>
          <p>
            Cuidamos da instalação e montagem no local de produtos em ferro, alumínio ou aço inox.
          </p>
          <p>
            Atendemos projetos de edifícios, imóveis privados, áreas comuns, projetos públicos e hotéis.
            Seja para <strong class="text-gray-800">fabricação, reforma ou manutenção</strong>,
            você pode contar com nossa equipe.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 sm:gap-8 mt-10 pt-10 border-t border-zinc-200">
          <div class="text-center p-3 rounded-lg bg-zinc-50 ring-1 ring-zinc-200/80 shadow-sm">
            <div class="font-display text-3xl sm:text-4xl font-bold text-brand-700">15+</div>
            <div class="text-[11px] sm:text-sm text-zinc-500 mt-1 font-semibold uppercase tracking-wide">Anos</div>
          </div>
          <div class="text-center p-3 rounded-lg bg-zinc-50 ring-1 ring-zinc-200/80 shadow-sm">
            <div class="font-display text-3xl sm:text-4xl font-bold text-brand-700">500+</div>
            <div class="text-[11px] sm:text-sm text-zinc-500 mt-1 font-semibold uppercase tracking-wide">Projetos</div>
          </div>
          <div class="text-center p-3 rounded-lg bg-zinc-50 ring-1 ring-zinc-200/80 shadow-sm">
            <div class="font-display text-3xl sm:text-4xl font-bold text-spark-600">100%</div>
            <div class="text-[11px] sm:text-sm text-zinc-500 mt-1 font-semibold uppercase tracking-wide">Compromisso</div>
          </div>
        </div>
      </div>

      <!-- Image -->
      <div class="order-1 lg:order-2 relative">
        <div class="relative rounded-xl overflow-hidden shadow-industrial ring-1 ring-zinc-900/10">
          <Image
            src={aboutImg}
            alt="Obras de serralheria em Botucatu SP — instalação de estruturas metálicas"
            class="w-full h-auto object-cover"
            widths={[480, 640, 800]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            loading="lazy"
            format="webp"
            quality={80}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-900/30 to-transparent"></div>
        </div>
        <!-- Decorative elements -->
        <div class="absolute -bottom-5 -left-5 w-28 h-28 bg-gradient-to-br from-spark-400/30 to-brand-600/20 rounded-lg -z-10 blur-sm" aria-hidden="true"></div>
        <div class="absolute -top-5 -right-5 w-36 h-36 bg-gradient-to-br from-brand-500/20 to-spark-500/15 rounded-lg -z-10 blur-sm" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>
