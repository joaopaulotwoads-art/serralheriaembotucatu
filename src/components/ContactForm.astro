---

---

<section id="contato" class="relative py-20 lg:py-28 bg-gray-900 overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-600/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-600/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-brand-600/20 text-brand-300 text-sm font-semibold rounded-full mb-4 border border-brand-500/20">
        Orçamento Gratuito
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        Faça seu orçamento <span class="text-brand-400">gratuitamente</span>
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg">
        Para isso, preencha o formulário abaixo e nossa equipe entrará em contato o mais breve possível.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
      <!-- Contact Info -->
      <div class="lg:col-span-2 space-y-8">
        <div>
          <h3 class="text-xl font-bold text-white mb-6">Informações de Contato</h3>
          
          <!-- Email -->
          <div class="flex items-start gap-4 mb-6 group">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-600/20 rounded-xl flex items-center justify-center group-hover:bg-brand-600/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400 mb-1">Email</p>
              <a href="mailto:contato@serralheriambauru.com.br" class="text-white hover:text-brand-300 transition-colors font-medium">
                contato@serralheriambauru.com.br
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4 mb-6 group">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-600/20 rounded-xl flex items-center justify-center group-hover:bg-brand-600/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400 mb-1">Telefone / WhatsApp</p>
              <a href="tel:+5514996804609" class="text-white hover:text-brand-300 transition-colors font-medium">
                (14) 99680-4609
              </a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-600/20 rounded-xl flex items-center justify-center group-hover:bg-brand-600/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400 mb-1">Endereço</p>
              <p class="text-white font-medium">
                Bauru - SP<br />
                <span class="text-gray-400 text-sm">Atendemos toda a região</span>
              </p>
            </div>
          </div>
        </div>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/5514996804609?text=Ol%C3%A1!%20Gostaria%20de%20solicitar%20um%20or%C3%A7amento%20de%20serralheria."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-6 py-4 bg-green-600 text-white font-semibold rounded-xl hover:bg-green-500 transition-all duration-300 hover:shadow-xl hover:shadow-green-600/25 w-full justify-center"
          aria-label="Enviar mensagem pelo WhatsApp para solicitar orçamento"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chamar no WhatsApp
        </a>
      </div>

      <!-- Form -->
      <div class="lg:col-span-3">
        <form
          id="contact-form"
          action="https://formsubmit.co/contato@serralheriambauru.com.br"
          method="POST"
          class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 sm:p-8 space-y-5"
        >
          <!-- FormSubmit config -->
          <input type="hidden" name="_subject" value="Novo Orçamento - Serralheria Bauru" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="text" name="_honey" style="display:none" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <!-- Nome -->
            <div>
              <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Nome</label>
              <input
                type="text"
                id="name"
                name="nome"
                required
                placeholder="Seu nome completo"
                class="w-full px-4 py-3.5 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all duration-300"
                aria-label="Digite seu nome completo"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Seu Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="seu@email.com"
                class="w-full px-4 py-3.5 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all duration-300"
                aria-label="Digite seu endereço de email"
              />
            </div>
          </div>

          <!-- Telefone -->
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-300 mb-2">Telefone</label>
            <input
              type="tel"
              id="phone"
              name="telefone"
              required
              placeholder="(14) 99999-9999"
              class="w-full px-4 py-3.5 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all duration-300"
              aria-label="Digite seu número de telefone"
            />
          </div>

          <!-- Mensagem -->
          <div>
            <label for="message" class="block text-sm font-medium text-gray-300 mb-2">Mensagem</label>
            <textarea
              id="message"
              name="mensagem"
              rows="4"
              required
              placeholder="Descreva o serviço que precisa..."
              class="w-full px-4 py-3.5 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all duration-300 resize-none"
              aria-label="Descreva o serviço de serralheria que você precisa"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full sm:w-auto btn-primary text-lg px-10 py-4"
            aria-label="Enviar formulário de orçamento de serralheria"
          >
            ENVIAR
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
