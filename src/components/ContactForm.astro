---
import { SITE_ADDRESS_LINES, SITE_MAPS_URL } from '../data/site';
---


<section id="contato" class="contact-section-bg relative overflow-hidden py-20 lg:py-28">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-spark-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-zinc-300/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <span class="eyebrow inline-block px-4 py-2 bg-spark-500/10 mb-5 rounded-sm border border-spark-500/25">
        Orçamento gratuito
      </span>
      <h2 class="section-title mb-5">
        Faça seu orçamento <span class="text-gradient-amber">gratuitamente</span>
      </h2>
      <p class="text-zinc-600 max-w-xl mx-auto text-lg leading-relaxed">
        Para isso, preencha o formulário abaixo e nossa equipe entrará em contato o mais breve possível.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
      <!-- Contact Info -->
      <div class="lg:col-span-2 space-y-8">
        <div>
          <h3 class="font-display text-lg font-bold text-zinc-900 uppercase tracking-wide mb-6">Informações de contato</h3>

          <!-- Email -->
          <div class="flex items-start gap-4 mb-6 group">
            <div class="flex-shrink-0 w-12 h-12 bg-zinc-100 rounded-md flex items-center justify-center border border-zinc-200 group-hover:border-spark-500/40 group-hover:bg-spark-500/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-spark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-zinc-500 mb-1">Email</p>
              <a href="mailto:contato@serralheriaembotucatu.com.br" class="text-zinc-900 hover:text-spark-600 transition-colors font-medium">
                contato@serralheriaembotucatu.com.br
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4 mb-6 group">
            <div class="flex-shrink-0 w-12 h-12 bg-zinc-100 rounded-md flex items-center justify-center border border-zinc-200 group-hover:border-spark-500/40 group-hover:bg-spark-500/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-spark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-zinc-500 mb-1">Telefone / WhatsApp</p>
              <a href="tel:+5514981651674" class="text-zinc-900 hover:text-spark-600 transition-colors font-medium">
                (14) 98165-1674
              </a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-zinc-100 rounded-md flex items-center justify-center border border-zinc-200 group-hover:border-spark-500/40 group-hover:bg-spark-500/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-spark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-zinc-500 mb-1">Endereço</p>
              <p class="text-zinc-900 font-medium">
                {SITE_ADDRESS_LINES[0]}
                <br />
                {SITE_ADDRESS_LINES[1]}
              </p>
              <p class="text-zinc-500 text-sm mt-1">Atendemos toda a região</p>
              <a
                href={SITE_MAPS_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-flex items-center gap-1.5 text-spark-600 hover:text-spark-700 text-sm font-medium underline-offset-2 hover:underline"
              >
                Abrir no Google Maps
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/5514981651674?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembotucatu.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp w-full justify-center"
          aria-label="Enviar mensagem pelo WhatsApp para solicitar orçamento"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chamar no WhatsApp
        </a>
      </div>

      <!-- Form -->
      <div class="lg:col-span-3">
        <form
          id="contact-form"
          action="https://formsubmit.co/contato@serralheriaembotucatu.com.br"
          method="POST"
          class="bg-white border border-zinc-200 rounded-xl p-6 sm:p-8 space-y-5 shadow-md"
        >
          <input type="hidden" name="_subject" value="Novo Orçamento - Serralheria Botucatu" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="text" name="_honey" style="display:none" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-zinc-700 mb-2">Nome</label>
              <input
                type="text"
                id="name"
                name="nome"
                required
                placeholder="Seu nome completo"
                class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-300 rounded-lg text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-spark-500/50 focus:border-spark-500/50 transition-all duration-300"
                aria-label="Digite seu nome completo"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-zinc-700 mb-2">Seu Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="seu@email.com"
                class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-300 rounded-lg text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-spark-500/50 focus:border-spark-500/50 transition-all duration-300"
                aria-label="Digite seu endereço de email"
              />
            </div>
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-zinc-700 mb-2">Telefone</label>
            <input
              type="tel"
              id="phone"
              name="telefone"
              required
              placeholder="(14) 99999-9999"
              class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-300 rounded-lg text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-spark-500/50 focus:border-spark-500/50 transition-all duration-300"
              aria-label="Digite seu número de telefone"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-zinc-700 mb-2">Mensagem</label>
            <textarea
              id="message"
              name="mensagem"
              rows="4"
              required
              placeholder="Descreva o serviço que precisa..."
              class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-300 rounded-lg text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-spark-500/50 focus:border-spark-500/50 transition-all duration-300 resize-none"
              aria-label="Descreva o serviço de serralheria que você precisa"
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-submit"
            aria-label="Enviar formulário de orçamento de serralheria"
          >
            ENVIAR
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
