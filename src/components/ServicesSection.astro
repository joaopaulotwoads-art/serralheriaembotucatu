---
import ServiceCard from './ServiceCard.astro';
import { services } from '../data/services';

// Import all images dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.png');
---

<section id="servicos" class="relative py-20 lg:py-28 overflow-hidden">
  <div class="absolute inset-0 metal-texture opacity-40 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-zinc-100/80 via-zinc-50 to-white pointer-events-none" aria-hidden="true"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <span
        class="eyebrow inline-block px-4 py-2 bg-brand-100/90 text-brand-800 rounded-sm mb-5 ring-1 ring-brand-200/80 shadow-sm"
      >
        Nossos serviços
      </span>
      <h2 class="section-title mb-5">
        Serviços e produtos
      </h2>
      <p class="text-zinc-600 max-w-2xl mx-auto text-lg leading-relaxed">
        Oferecemos uma linha completa de serviços em serralheria para residências e comércios em Botucatu e região.
      </p>
      <div class="flex justify-center gap-1.5 mt-8" aria-hidden="true">
        <span class="h-1 w-10 rounded-full bg-gradient-to-r from-spark-500 to-brand-600"></span>
        <span class="h-1 w-3 rounded-full bg-brand-400/50"></span>
        <span class="h-1 w-3 rounded-full bg-brand-300/40"></span>
      </div>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
      {services.map(async (service, index) => {
        const imagePath = `../assets/images/${service.image}.png`;
        const imageModule = images[imagePath];
        const resolvedImage = imageModule ? (await imageModule()).default : null;

        return resolvedImage ? (
          <ServiceCard
            title={service.title}
            slug={service.slug}
            imageSrc={resolvedImage}
            alt={service.alt}
            index={index}
          />
        ) : null;
      })}
    </div>
  </div>
</section>
