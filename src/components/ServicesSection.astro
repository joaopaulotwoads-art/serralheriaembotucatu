---
import ServiceCard from './ServiceCard.astro';
import { services } from '../data/services';

// Import all images dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.png');
---

<section id="servicos" class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-brand-100 text-brand-700 text-sm font-semibold rounded-full mb-4">
        Nossos Serviços
      </span>
      <h2 class="section-title mb-4">
        SERVIÇOS E PRODUTOS — SERRALHERIA
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto text-lg">
        Oferecemos uma linha completa de serviços em serralheria para residências e comércios em Bauru e região.
      </p>
      <div class="w-24 h-1.5 bg-gradient-to-r from-brand-500 to-brand-700 mx-auto mt-6 rounded-full"></div>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
      {services.map(async (service, index) => {
        const imagePath = `../assets/images/${service.image}.png`;
        const imageModule = images[imagePath];
        const resolvedImage = imageModule ? (await imageModule()).default : null;

        return resolvedImage ? (
          <ServiceCard
            title={service.title}
            slug={service.slug}
            imageSrc={resolvedImage}
            alt={service.alt}
            index={index}
          />
        ) : null;
      })}
    </div>
  </div>
</section>
