---
import ServiceCard from './ServiceCard.astro';
import { services } from '../data/services';
import {
  SERVICE_CATEGORY_FILTER,
  SERVICE_CATEGORY_LABEL,
  SERVICE_FILTER_TABS,
  serviceGridClass,
} from '../data/serviceCategories';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/images/*.png');
---

<section id="servicos" class="relative overflow-hidden bg-[#F5F5F5] pb-10 pt-20 lg:pb-14 lg:pt-28">
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 max-w-3xl text-center lg:mb-14">
      <span class="eyebrow mb-4 inline-block border border-spark-500/25 bg-spark-500/10 px-4 py-2">
        Nossos serviços
      </span>
      <h2 class="section-title mb-5">Serviços e produtos</h2>
      <p class="mx-auto max-w-2xl text-lg leading-relaxed text-zinc-600">
        Oferecemos uma linha completa de serviços em serralheria para residências e comércios em Botucatu e região.
      </p>
    </div>

    <!-- Filtros por categoria -->
    <div
      class="mb-10 flex flex-wrap justify-center gap-2"
      role="tablist"
      aria-label="Filtrar serviços por categoria"
      id="service-filters"
    >
      {SERVICE_FILTER_TABS.map((tab, i) => (
        <button
          type="button"
          role="tab"
          class:list={['filter-tab', i === 0 && 'is-active']}
          data-filter={tab.id}
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Grid assimétrico -->
    <div
      id="services-grid"
      class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:auto-rows-[minmax(200px,auto)] stagger-children"
    >
      {services.map(async (service, index) => {
        const imagePath = `../assets/images/${service.image}.png`;
        const imageModule = images[imagePath];
        const resolvedImage = imageModule ? (await imageModule()).default : null;
        const categoryFilter = SERVICE_CATEGORY_FILTER[service.slug] ?? 'estruturas';
        const categoryLabel = SERVICE_CATEGORY_LABEL[service.slug] ?? 'Serralheria';

        return resolvedImage ? (
          <ServiceCard
            title={service.title}
            slug={service.slug}
            imageSrc={resolvedImage}
            alt={service.alt}
            categoryLabel={categoryLabel}
            categoryFilter={categoryFilter}
            intro={service.intro}
            featured={index === 0}
            gridClass={serviceGridClass(index)}
            index={index}
          />
        ) : null;
      })}
    </div>
  </div>
</section>

<script>
  const filters = document.getElementById('service-filters');
  const cards = document.querySelectorAll<HTMLElement>('[data-service-card]');

  filters?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter]');
    if (!btn) return;

    const filter = btn.dataset.filter ?? 'all';

    filters.querySelectorAll('[data-filter]').forEach((tab) => {
      const el = tab as HTMLButtonElement;
      const active = el === btn;
      el.classList.toggle('is-active', active);
      el.setAttribute('aria-selected', active ? 'true' : 'false');
    });

    cards.forEach((card) => {
      const cat = card.dataset.category;
      const show = filter === 'all' || cat === filter;
      card.classList.toggle('hidden', !show);
    });
  });
</script>
