---
import { Image } from 'astro:assets';
import heroBg from '../assets/images/severino-oficina-2.png';
---

<section id="hero" class="relative min-h-[88vh] flex items-center overflow-hidden">
  <!-- Background: foto mais escura e menos “lavada” -->
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt="Serralheria em Botucatu SP — estruturas metálicas, coberturas e obras com caminhão munck"
      class="h-full w-full object-cover object-center brightness-[0.42] contrast-[1.08] saturate-[0.9] scale-105"
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      format="webp"
      quality={80}
    />
    <!-- Escurecimento uniforme + vignette para a foto clara não brigar com o texto -->
    <div class="absolute inset-0 bg-zinc-950/55"></div>
    <div
      class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/92 to-zinc-950/25 sm:to-zinc-900/15"
      aria-hidden="true"
    ></div>
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"
      aria-hidden="true"
    ></div>
    <!-- Granulado só no hero, bem leve -->
    <div class="absolute inset-0 grain-overlay opacity-[0.06]" aria-hidden="true"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 py-28 sm:px-6 sm:py-32 lg:px-8 lg:py-36">
    <div class="max-w-xl rounded-2xl border border-white/10 bg-zinc-950/55 px-6 py-8 shadow-2xl shadow-black/40 backdrop-blur-md sm:max-w-2xl sm:px-8 sm:py-10">
      <!-- Badge -->
      <div
        class="mb-6 inline-flex items-center gap-2.5 rounded-md border border-spark-500/40 bg-black/35 px-3.5 py-2 text-[13px] font-semibold text-spark-200 backdrop-blur-sm animate-fade-in-up"
      >
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-spark-400 opacity-50"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-spark-400"></span>
        </span>
        <span class="tracking-wide">Atendemos toda a região de Botucatu</span>
      </div>

      <!-- H1: Sora = leitura nítida; cor sólida no destaque (sem gradiente no texto) -->
      <h1
        class="animate-fade-in-up font-sans text-4xl font-extrabold leading-[1.12] tracking-tight text-white sm:text-5xl lg:text-6xl"
        style="animation-delay: 0.08s; text-shadow: 0 2px 24px rgba(0,0,0,0.65), 0 1px 3px rgba(0,0,0,0.9)"
      >
        Serralheria em <span class="mt-1 block text-spark-300 sm:mt-2">Botucatu</span>
      </h1>

      <!-- Checkmarks -->
      <ul class="mb-8 mt-8 space-y-3.5 animate-fade-in-up" style="animation-delay: 0.16s">
        <li class="flex items-start gap-3 text-[15px] leading-snug text-zinc-100 sm:text-base">
          <span
            class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded border border-spark-500/50 bg-spark-500/20"
          >
            <svg class="h-3.5 w-3.5 text-spark-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          Entrega no prazo.
        </li>
        <li class="flex items-start gap-3 text-[15px] leading-snug text-zinc-100 sm:text-base">
          <span
            class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded border border-spark-500/50 bg-spark-500/20"
          >
            <svg class="h-3.5 w-3.5 text-spark-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          Preços que cabem no seu orçamento.
        </li>
        <li class="flex items-start gap-3 text-[15px] leading-snug text-zinc-100 sm:text-base">
          <span
            class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded border border-spark-500/50 bg-spark-500/20"
          >
            <svg class="h-3.5 w-3.5 text-spark-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          Excelência em cada detalhe.
        </li>
      </ul>

      <!-- Subtitle -->
      <p
        class="animate-fade-in-up mb-10 max-w-lg border-l-[3px] border-spark-500 pl-4 text-base leading-relaxed text-zinc-200 sm:text-lg"
        style="animation-delay: 0.24s"
      >
        Portões, coberturas, pergolados, escadas, estruturas metálicas e artefatos em aço e alumínio.
      </p>

      <!-- CTA -->
      <div class="flex animate-fade-in-up flex-col gap-3 sm:flex-row sm:gap-4" style="animation-delay: 0.32s">
        <a
          href="https://wa.me/5514981651674?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembotucatu.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary justify-center px-8 py-4 text-sm sm:justify-start sm:px-10 sm:py-5 sm:text-base"
          aria-label="Solicitar orçamento gratuito de serralheria em Botucatu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Solicitar orçamento
        </a>
        <a
          href="#servicos"
          class="inline-flex items-center justify-center gap-2 rounded-md border-2 border-white/50 bg-white/10 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:bg-white hover:text-zinc-900 sm:justify-start sm:py-5 sm:text-base"
          aria-label="Ver serviços de serralheria disponíveis"
        >
          Ver serviços
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll -->
  <div class="absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-1.5 text-zinc-400">
    <span class="text-[10px] font-medium uppercase tracking-widest text-zinc-500">Role</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
