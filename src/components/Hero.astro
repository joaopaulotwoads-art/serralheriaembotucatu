---
import { Image } from 'astro:assets';
import heroBg from '../assets/images/hero-bg.png';
---

<section id="hero" class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt="Soldador profissional realizando trabalho de serralheria em Bauru SP"
      class="w-full h-full object-cover"
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      format="webp"
      quality={80}
    />
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-900/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/50 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-40">
    <div class="max-w-2xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-600/20 border border-brand-500/30 rounded-full text-brand-300 text-sm font-medium mb-6 animate-fade-in-up backdrop-blur-sm">
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-pulse"></span>
        Atendemos toda a região de Bauru
      </div>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6 animate-fade-in-up" style="animation-delay: 0.1s">
        SERRALHERIA EM<br />
        <span class="text-gradient bg-gradient-to-r from-brand-400 to-brand-300 bg-clip-text text-transparent">BAURU</span>
      </h1>

      <!-- Checkmarks -->
      <ul class="space-y-3 mb-8 animate-fade-in-up" style="animation-delay: 0.2s">
        <li class="flex items-center gap-3 text-gray-200">
          <div class="flex-shrink-0 w-6 h-6 bg-brand-600/30 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="font-medium">Entrega No Prazo.</span>
        </li>
        <li class="flex items-center gap-3 text-gray-200">
          <div class="flex-shrink-0 w-6 h-6 bg-brand-600/30 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="font-medium">Preços que cabem no seu orçamento.</span>
        </li>
        <li class="flex items-center gap-3 text-gray-200">
          <div class="flex-shrink-0 w-6 h-6 bg-brand-600/30 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="font-medium">Excelência garantida em cada detalhe.</span>
        </li>
      </ul>

      <!-- Subtitle -->
      <p class="text-lg text-gray-300 mb-10 max-w-xl leading-relaxed animate-fade-in-up" style="animation-delay: 0.3s">
        Portões, Coberturas, Pergolado, Escadas, Estruturas metálicas e tudo mais em artefatos de metal
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up" style="animation-delay: 0.4s">
        <a
          href="https://wa.me/5514996804609?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembauru.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-lg px-10 py-5 shadow-2xl shadow-brand-600/30"
          aria-label="Solicitar orçamento gratuito de serralheria em Bauru"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Solicitar Orçamento
        </a>
        <a
          href="#servicos"
          class="btn-outline border-white/30 text-white hover:bg-white hover:text-gray-900 text-lg px-8 py-5"
          aria-label="Ver serviços de serralheria disponíveis"
        >
          Ver Serviços
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
