---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/severino-oficina-2.png';
---

<section id="hero" class="bg-white py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">

      <!-- Coluna de texto -->
      <div>
        <div class="mb-6 inline-flex items-center gap-2 border border-spark-500/40 bg-spark-500/8 px-4 py-2">
          <svg class="h-4 w-4 text-spark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="font-display text-sm uppercase tracking-[0.18em] text-spark-600">Atendemos toda a região de Botucatu</span>
        </div>

        <h1 class="font-display text-[clamp(3rem,8vw,5.5rem)] uppercase leading-[0.92] tracking-wide text-[#1a1a1a]">
          Serralheria em
          <span class="mt-1 block text-spark-500">Botucatu</span>
        </h1>

        <p class="mt-5 text-sm font-medium uppercase tracking-[0.2em] text-[#555555]">
          Fabricação · instalação · manutenção
        </p>

        <ul class="mb-8 mt-8 space-y-3 border-l-2 border-spark-500/50 pl-5">
          <li class="flex items-center gap-3 text-base text-[#555555]">
            <svg class="h-4 w-4 shrink-0 text-spark-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Entrega no prazo.
          </li>
          <li class="flex items-center gap-3 text-base text-[#555555]">
            <svg class="h-4 w-4 shrink-0 text-spark-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Preços que cabem no seu orçamento.
          </li>
          <li class="flex items-center gap-3 text-base text-[#555555]">
            <svg class="h-4 w-4 shrink-0 text-spark-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Excelência em cada detalhe.
          </li>
        </ul>

        <p class="mb-10 max-w-xl text-base leading-relaxed text-[#555555] sm:text-lg">
          Portões, coberturas, pergolados, escadas, estruturas metálicas e artefatos em aço e alumínio.
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:gap-4">
          <a
            href="https://wa.me/5514981651674?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembotucatu.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary justify-center sm:justify-start"
            aria-label="Solicitar orçamento gratuito de serralheria em Botucatu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            Solicitar orçamento
          </a>
          <a
            href="#servicos"
            class="font-display inline-flex items-center justify-center gap-2 rounded-sm border border-zinc-800 px-6 py-3 text-base uppercase tracking-[0.12em] text-zinc-800 transition-all duration-300 hover:bg-zinc-100 sm:justify-start"
            aria-label="Ver serviços de serralheria disponíveis"
          >
            Ver serviços
          </a>
        </div>
      </div>

      <!-- Coluna da foto -->
      <div class="relative">
        <Image
          src={heroImg}
          alt="Serralheria em Botucatu SP — estruturas metálicas, coberturas e obras"
          class="w-full rounded-sm object-cover shadow-lg ring-1 ring-zinc-200"
          widths={[480, 640, 800]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          loading="eager"
          format="webp"
          quality={80}
        />
        <div class="absolute -bottom-4 -left-4 border border-spark-500/30 bg-white px-5 py-3 shadow-md">
          <p class="font-display text-3xl font-normal text-spark-500">15+</p>
          <p class="text-xs font-medium uppercase tracking-wider text-zinc-500">Anos de experiência</p>
        </div>
      </div>

    </div>
  </div>
</section>
