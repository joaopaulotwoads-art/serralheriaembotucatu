---
import { Image } from 'astro:assets';
import heroBg from '../assets/images/severino-oficina-2.png';
---

<section id="hero" class="relative flex min-h-[92vh] items-center overflow-hidden">
  <div class="absolute inset-0 bg-zinc-700">
    <Image
      src={heroBg}
      alt="Serralheria em Botucatu SP — estruturas metálicas, coberturas e obras com caminhão munck"
      class="h-full w-full scale-105 object-cover object-center brightness-[0.55] contrast-[1.1] saturate-[0.85]"
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      format="webp"
      quality={80}
    />
    <!-- Elemento diagonal — chapa de aço -->
    <div
      class="pointer-events-none absolute -right-[20%] top-0 h-full w-[55%] skew-x-[-12deg] border-l border-zinc-500/20 bg-gradient-to-l from-zinc-400/10 via-transparent to-transparent"
      aria-hidden="true"
    ></div>
    <svg
      class="pointer-events-none absolute bottom-0 left-0 w-full text-zinc-500/15"
      viewBox="0 0 1200 80"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <path d="M0 80 L0 40 L400 0 L1200 60 L1200 80 Z" fill="currentColor" />
    </svg>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 py-28 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
    <div class="relative max-w-3xl">
      <div
        class="mb-8 inline-flex items-center gap-2.5 border border-spark-500/35 bg-zinc-900/70 px-4 py-2 backdrop-blur-sm"
      >
        <svg class="h-4 w-4 text-spark-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 0a3 3 0 104.243 4.243 3 3 0 00-4.243-4.243z" />
        </svg>
        <span class="font-display text-sm uppercase tracking-[0.18em] text-spark-300">Atendemos toda a região de Botucatu</span>
      </div>

      <h1
        class="font-display text-[clamp(3.9rem,12vw,8.4rem)] uppercase leading-[0.92] tracking-wide text-white"
        style="text-shadow: 0 4px 32px rgba(0,0,0,0.5)"
      >
        Serralheria em
        <span class="mt-1 block text-spark-400">Botucatu</span>
      </h1>

      <p class="mt-6 max-w-md text-sm font-medium uppercase tracking-[0.2em] text-zinc-500">
        Fabricação · instalação · manutenção
      </p>

      <ul class="mb-8 mt-10 space-y-3 border-l-2 border-spark-500/50 pl-5">
        <li class="flex items-center gap-3 text-base text-zinc-200">
          <svg class="h-4 w-4 shrink-0 text-spark-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Entrega no prazo.
        </li>
        <li class="flex items-center gap-3 text-base text-zinc-200">
          <svg class="h-4 w-4 shrink-0 text-spark-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Preços que cabem no seu orçamento.
        </li>
        <li class="flex items-center gap-3 text-base text-zinc-200">
          <svg class="h-4 w-4 shrink-0 text-spark-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Excelência em cada detalhe.
        </li>
      </ul>

      <p class="mb-10 max-w-xl text-base leading-relaxed text-zinc-400 sm:text-lg">
        Portões, coberturas, pergolados, escadas, estruturas metálicas e artefatos em aço e alumínio.
      </p>

      <div class="flex flex-col gap-3 sm:flex-row sm:gap-4">
        <a
          href="https://wa.me/5514981651674?text=Ol%C3%A1!%20Encontrei%20o%20contato%20de%20voc%C3%AAs%20atrav%C3%A9s%20do%20site%20serralheriaembotucatu.com.br%20e%20gostaria%20de%20solicitar%20um%20or%C3%A7amento"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary justify-center sm:justify-start"
          aria-label="Solicitar orçamento gratuito de serralheria em Botucatu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Solicitar orçamento
        </a>
        <a href="#servicos" class="btn-outline justify-center sm:justify-start" aria-label="Ver serviços de serralheria disponíveis">
          Ver serviços
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-1 text-zinc-600">
    <span class="font-display text-[10px] uppercase tracking-[0.3em]">Role</span>
    <svg class="h-4 w-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
