---
import { services } from '../data/services';
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo.png';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Serviços', href: '/#servicos' },
  { label: 'Blog', href: '/blog' },
  { label: 'Sobre Nós', href: '/sobre-nos/' },
  { label: 'Contato', href: '/contato/' },
];
---

<footer class="bg-gray-950 text-gray-400" id="localizacao">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Logo & Description -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex mb-5 group" aria-label="Serralheria Bauru - Página Inicial">
          <Image
            src={logoImg}
            alt="Serralheria Bauru Logo"
            class="h-10 w-auto object-contain"
            width={200}
            height={57}
            loading="lazy"
          />
        </a>
        <p class="text-sm leading-relaxed mb-5">
          Soluções completas em serralheria para Bauru e região. Qualidade, pontualidade e preço justo direto da fábrica.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="https://www.instagram.com/serralheriaembauru/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/5 hover:bg-brand-600 rounded-lg flex items-center justify-center transition-all duration-300 hover:scale-110" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 bg-white/5 hover:bg-brand-600 rounded-lg flex items-center justify-center transition-all duration-300 hover:scale-110" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Serviços -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5">Serviços</h3>
        <ul class="space-y-2.5">
          {services.slice(0, 8).map((service) => (
            <li>
              <a href={`/${service.slug}/`} class="text-sm hover:text-brand-400 transition-colors duration-200 hover:translate-x-1 inline-block">
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links Rápidos -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5">Links Rápidos</h3>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-brand-400 transition-colors duration-200 hover:translate-x-1 inline-block">
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- More services -->
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mt-8 mb-5">Mais Serviços</h3>
        <ul class="space-y-2.5">
          {services.slice(8).map((service) => (
            <li>
              <a href={`/${service.slug}/`} class="text-sm hover:text-brand-400 transition-colors duration-200 hover:translate-x-1 inline-block">
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contato -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5">Contato</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div class="text-sm">
              <p class="text-white font-medium">Serralheria Bauru</p>
              <p>Bauru - SP</p>
              <p>Seg - Sex: 07:00 - 19:00</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+5514996804609" class="text-sm hover:text-brand-400 transition-colors">(14) 99680-4609</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-brand-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <a href="https://wa.me/5514996804609" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-brand-400 transition-colors">WhatsApp</a>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contato@serralheriambauru.com.br" class="text-sm hover:text-brand-400 transition-colors">contato@serralheriambauru.com.br</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-sm text-gray-500">
        Serralheria em Bauru &copy; Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
