---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/portfolio-portoes/*.png',
  { eager: true }
);

const items = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([path, mod], index) => ({
    src: mod.default,
    alt: `Portão e serralheria em metal — modelo ${index + 1}, trabalho realizado em Botucatu`,
  }));

const total = items.length;
---

<section id="galeria-portoes" class="mb-12 scroll-mt-24" aria-labelledby="galeria-portoes-heading">
  <div class="relative rounded-xl border border-zinc-300/90 bg-gradient-to-br from-zinc-100 via-white to-zinc-50 p-6 sm:p-8 shadow-industrial-sm overflow-hidden">
    <div class="absolute inset-0 metal-texture opacity-30 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-spark-500 via-brand-500 to-brand-700" aria-hidden="true"></div>
    <div class="relative">
    <div class="text-center mb-8">
      <span
        class="eyebrow inline-block px-4 py-2 bg-brand-100 text-brand-800 rounded-sm mb-4 ring-1 ring-brand-200/80"
      >
        Portfólio
      </span>
      <h2 id="galeria-portoes-heading" class="font-display text-2xl sm:text-3xl font-bold text-zinc-900 tracking-display-tight uppercase mb-3">
        Modelos de portão
      </h2>
      <p class="text-zinc-600 text-sm sm:text-base max-w-2xl mx-auto leading-relaxed">
        Fotos reais do nosso trabalho — arraste ou use as setas para ver mais.
      </p>
    </div>

    <div class="relative" data-carousel-portoes>
      <div
        data-carousel-track
        class="relative flex w-full snap-x snap-mandatory snap-always overflow-x-auto scroll-smooth touch-pan-x rounded-xl bg-gray-900/5 ring-1 ring-gray-200/80 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
        tabindex="0"
        aria-roledescription="carrossel"
        aria-label="Galeria de modelos de portão"
      >
        {
          items.map((item, i) => (
            <div
              data-carousel-slide
              class="box-border w-full shrink-0 grow-0 snap-center snap-always basis-full p-2 sm:p-4"
              style="flex: 0 0 100%; width: 100%; max-width: 100%;"
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <figure class="mx-auto flex max-h-[min(70vh,560px)] min-h-[200px] w-full max-w-4xl items-center justify-center overflow-hidden rounded-xl bg-gray-200 p-2 shadow-md sm:p-3">
                <Image
                  src={item.src}
                  alt={item.alt}
                  class="h-auto max-h-[min(70vh,520px)] w-full object-contain object-center"
                  widths={[640, 960, 1280]}
                  sizes="(max-width: 768px) 100vw, 896px"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  format="webp"
                  quality={78}
                />
              </figure>
            </div>
          ))
        }
      </div>

      <div
        class="relative z-20 mt-4 flex flex-wrap items-center justify-center gap-3 sm:absolute sm:inset-x-0 sm:bottom-4 sm:mt-0 sm:justify-between sm:px-2"
      >
        <button
          type="button"
          data-carousel-prev
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-800 shadow-md transition hover:bg-brand-50 hover:border-brand-200 hover:text-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
          aria-label="Foto anterior"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <span
          data-carousel-counter
          class="order-first w-full text-center text-sm font-medium text-gray-600 tabular-nums sm:order-none sm:absolute sm:bottom-0 sm:left-1/2 sm:w-auto sm:-translate-x-1/2 sm:translate-y-1/2 sm:rounded-full sm:bg-white/95 sm:px-3 sm:py-1 sm:text-xs sm:shadow sm:ring-1 sm:ring-gray-200"
        >
          1 / {total}
        </span>
        <button
          type="button"
          data-carousel-next
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-800 shadow-md transition hover:bg-brand-50 hover:border-brand-200 hover:text-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
          aria-label="Próxima foto"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function getIndex(track, slides) {
      const n = slides.length;
      if (n === 0) return 0;
      const w = track.clientWidth || 1;
      let best = 0;
      let bestDist = Infinity;
      for (let i = 0; i < n; i++) {
        const d = Math.abs(slides[i].offsetLeft - track.scrollLeft);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      }
      return best;
    }

    function initPortoesCarousel(root) {
      if (root.dataset.carouselReady === 'true') return;
      var track = root.querySelector('[data-carousel-track]');
      var prev = root.querySelector('[data-carousel-prev]');
      var next = root.querySelector('[data-carousel-next]');
      var counter = root.querySelector('[data-carousel-counter]');
      var slides = root.querySelectorAll('[data-carousel-slide]');
      if (!track || !prev || !next || !counter || slides.length === 0) return;
      root.dataset.carouselReady = 'true';

      var n = slides.length;

      function syncAria(idx) {
        slides.forEach(function (slide, i) {
          slide.setAttribute('aria-hidden', i === idx ? 'false' : 'true');
        });
      }

      function updateCounter() {
        var idx = getIndex(track, slides);
        counter.textContent = idx + 1 + ' / ' + n;
        syncAria(idx);
      }

      var scrollEndTimer;
      function onScroll() {
        if (scrollEndTimer) clearTimeout(scrollEndTimer);
        scrollEndTimer = setTimeout(updateCounter, 100);
      }

      function go(delta) {
        var idx = getIndex(track, slides);
        var nextIdx = Math.max(0, Math.min(n - 1, idx + delta));
        var targetLeft = slides[nextIdx].offsetLeft;
        track.scrollTo({ left: targetLeft, behavior: 'smooth' });
        window.setTimeout(updateCounter, 350);
      }

      prev.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        go(-1);
      });
      next.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        go(1);
      });
      track.addEventListener('scroll', onScroll, { passive: true });

      track.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          go(-1);
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          go(1);
        }
      });

      window.addEventListener('resize', updateCounter);
      updateCounter();
    }

    function boot() {
      document.querySelectorAll('[data-carousel-portoes]').forEach(initPortoesCarousel);
    }

    document.addEventListener('astro:page-load', boot);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
</script>
