---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo-serralheria-botucatu.png';

interface Props {
  /** Header (default) uses larger mark; footer uses compact */
  variant?: 'header' | 'footer';
  class?: string;
}

const { variant = 'header', class: className = '' } = Astro.props;
const compact = variant === 'footer';
---

<div class:list={['flex items-center select-none', className]}>
  <Image
    src={logoImg}
    alt="Serralheria Botucatu"
    class:list={[
      'w-auto object-contain',
      compact ? 'h-9 sm:h-10' : 'h-11 sm:h-12',
    ]}
    widths={[240, 320, 400]}
    sizes={compact ? '(max-width: 640px) 200px, 240px' : '(max-width: 640px) 220px, 280px'}
    loading="eager"
    format="webp"
    quality={92}
  />
</div>
